#!/bin/bash
# Runs as root after the .pkg lays down the app. Turns the baked deploy.env into
# loaded launchd agents for the console user — the "it just works" part.
set -euo pipefail

APPDIR="/usr/local/outerloop"
ENV_FILE="$APPDIR/deploy.env"
[ -f "$ENV_FILE" ] || { echo "missing $ENV_FILE (pkg built wrong)"; exit 1; }
# shellcheck disable=SC1090
. "$ENV_FILE"   # ROLE, FAKE, PYTHON, PATHENV, SSH_KEY, VPS_HOST, TUNNEL_USER,
                # DEVICE, CAPS, HUB_URL, TOKEN, DEVICE_TOKENS

PYTHON="${PYTHON:-/opt/homebrew/bin/python3}"
PATHENV="${PATHENV:-/opt/homebrew/bin:/usr/bin:/bin}"
FAKE="${FAKE:-1}"

# The launchd agents load into the console user's GUI (Aqua) domain. Over SSH with
# nobody logged in, /dev/console is owned by root or loginwindow and gui/$CUID has
# no bootstrap target — bail loudly instead of a cryptic launchctl failure.
CUSER="$(stat -f %Su /dev/console)"
case "$CUSER" in
  root|loginwindow|"")
    echo "no desktop session (console user='$CUSER'). Run this pkg while logged into the Mac's desktop, not over SSH." >&2
    exit 1;;
esac
CUID="$(id -u "$CUSER")"
CHOME="$(dscl . -read "/Users/$CUSER" NFSHomeDirectory | sed 's/^NFSHomeDirectory: //')"
[ -n "$CHOME" ] && [ -d "$CHOME" ] || { echo "cannot resolve home dir for $CUSER" >&2; exit 1; }
# Resolve the interpreter target-side: prefer the baked path, but fall back to
# whatever python3 THIS machine has. Different Macs shelve it differently — Homebrew
# arm64 (/opt/homebrew), Homebrew Intel (/usr/local), or the CLT system python
# (/usr/bin). Baking one absolute path made the pkg fail on any machine that didn't
# match (e.g. a mini with Homebrew but no `brew install python`). The resolved value
# flows into every inbox call below AND the __PYTHON__ slot in the launchd plists.
if [ ! -x "$PYTHON" ]; then
  echo "baked python '$PYTHON' not executable here; auto-detecting python3" >&2
  for cand in /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3 \
              "$(command -v python3 2>/dev/null || true)"; do
    [ -n "$cand" ] && [ -x "$cand" ] && { PYTHON="$cand"; break; }
  done
fi
[ -x "$PYTHON" ] || { echo "no python3 found (looked in /opt/homebrew, /usr/local, /usr/bin, PATH)" >&2; exit 1; }
# App needs >= 3.9 (the CLT system python satisfies this); refuse an older one loudly.
"$PYTHON" -c 'import sys; raise SystemExit(0 if sys.version_info[:2] >= (3, 9) else 1)' 2>/dev/null \
  || { echo "python at $PYTHON is too old (need >= 3.9): $("$PYTHON" -V 2>&1)" >&2; exit 1; }
echo "using python: $PYTHON ($("$PYTHON" -V 2>&1))"

# Resolve claude the same way and bake an ABSOLUTE path into the plists (__CLAUDE_BIN__).
# The launchd jobs run with PATH=$PATHENV, which won't include a per-user ~/.local/bin
# install — the exact trap that would make real-mode agents FileNotFoundError. Prefer an
# explicit --claude-bin, else search where the Claude Code CLI self-installs per user.
# Only real mode (FAKE=0) actually needs it; resolving in FAKE is harmless.
if [ -z "${CLAUDE_BIN:-}" ] || [ ! -x "${CLAUDE_BIN:-}" ]; then
  for cand in "$CHOME/.local/bin/claude" "$CHOME/.claude/local/claude" \
              "$CHOME/.npm-global/bin/claude" "$CHOME/.bun/bin/claude" \
              /opt/homebrew/bin/claude /usr/local/bin/claude \
              "$(sudo -u "$CUSER" zsh -lic 'command -v claude' 2>/dev/null | tr -d '[:space:]')"; do
    [ -n "$cand" ] && [ -x "$cand" ] && { CLAUDE_BIN="$cand"; break; }
  done
fi
if [ -n "${CLAUDE_BIN:-}" ] && [ -x "$CLAUDE_BIN" ]; then
  echo "using claude: $CLAUDE_BIN"
elif [ "${FAKE:-1}" = "0" ]; then
  echo "WARNING: real mode (FAKE=0) but no claude found — agents will fail until INBOX_CLAUDE_BIN is set" >&2
fi
DATA="$CHOME/Library/Application Support/outerloop"
LA="$CHOME/Library/LaunchAgents"

install -d -o "$CUSER" -m 755 "$DATA" "$LA"

# The .pkg lays the tree down as root; the worker runs in the user domain and must be
# able to overwrite its own code when self-updating from the hub — hand it ownership.
chown -R "$CUSER" "$APPDIR"

asuser() { sudo -u "$CUSER" "$@"; }
inbox()  { asuser env INBOX_HOME="$DATA" PATH="$PATHENV" "$PYTHON" -m inbox "$@"; }
# launchctl into the user's GUI (Aqua) domain: must run inside that user's bootstrap
# context. From the root postinstall a bare `launchctl bootstrap gui/$CUID` returns
# "5: Input/output error"; `asuser` fixes it (same reason the inbox calls use it).
uctl()   { launchctl asuser "$CUID" launchctl "$@"; }

# --- db + auth bootstrap (always; idempotent) ---
( cd "$APPDIR" && inbox init )

if [ "$ROLE" = "hub" ]; then
  ( cd "$APPDIR" && inbox set-auth on )
  # Register every device's token (DEVICE_TOKENS="mini:tok pro:tok air:tok").
  for pair in ${DEVICE_TOKENS:-}; do
    ( cd "$APPDIR" && inbox set-token "${pair%%:*}" "${pair#*:}" )
  done
fi

# Read one EnvironmentVariables value from an existing rendered plist (empty if absent).
plist_env() { /usr/libexec/PlistBuddy -c "Print :EnvironmentVariables:$2" "$1" 2>/dev/null || true; }

# --- render a template -> ~/Library/LaunchAgents, then (re)load it ---
render_load() {
  local tpl="$1" out="$LA/$2"
  # On an UPGRADE the plist already exists and may hold identity/config the user set at
  # runtime in the menu-bar (device name, token, hub, caps, models) — values that live
  # ONLY in the plist, not in settings.json/DB. Re-rendering from the baked deploy.env
  # would wipe them (a pkg built with empty --token/--device would even DE-PAIR the box).
  # So prefer the existing plist's value for each runtime-owned key over the baked one.
  local dev="${DEVICE:-}" tok="${TOKEN:-}" hub="${HUB_URL:-}" caps="${CAPS:-[]}" models="${MODELS:-}" p
  if [ -f "$out" ]; then
    p="$(plist_env "$out" INBOX_DEVICE)";        [ -n "$p" ] && dev="$p"
    p="$(plist_env "$out" INBOX_DEVICE_TOKEN)";  [ -n "$p" ] && tok="$p"
    p="$(plist_env "$out" INBOX_HUB)";           [ -n "$p" ] && hub="$p"
    p="$(plist_env "$out" INBOX_CAPABILITIES)";  [ -n "$p" ] && caps="$p"
    p="$(plist_env "$out" INBOX_MODELS)";        [ -n "$p" ] && models="$p"
  fi
  sed -e "s#__PYTHON__#${PYTHON}#g" \
      -e "s#__PATH__#${PATHENV}#g" \
      -e "s#__APPDIR__#${APPDIR}#g" \
      -e "s#__HOME__#${CHOME}#g" \
      -e "s#__DATA__#${DATA}#g" \
      -e "s#__FAKE__#${FAKE}#g" \
      -e "s#__SSH_KEY__#${SSH_KEY:-}#g" \
      -e "s#__VPS_HOST__#${VPS_HOST:-}#g" \
      -e "s#__TUNNEL_USER__#${TUNNEL_USER:-tunnel}#g" \
      -e "s#__DEVICE__#${dev}#g" \
      -e "s#__CAPS__#${caps}#g" \
      -e "s#__HUB_URL__#${hub}#g" \
      -e "s#__TOKEN__#${tok}#g" \
      -e "s#__MODELS__#${models}#g" \
      -e "s#__HOST__#${HOST:-127.0.0.1}#g" \
      -e "s#__CLAUDE_BIN__#${CLAUDE_BIN:-}#g" \
      -e "s#__ALLOW_NO_CI__#${ALLOW_NO_CI:-0}#g" \
      -e "s#__ROLE__#${ROLE}#g" \
      -e "s#__DASH_URL__#${DASH_URL:-}#g" \
      "$APPDIR/deploy/mac/templates/$tpl" > "$out"
  chown "$CUSER" "$out"
  local label="${2%.plist}" i=0
  # Reload idempotently. `bootout` is ASYNC: on a REinstall the old label can linger a
  # moment, and bootstrapping while it's still present returns "5: Input/output error"
  # — which then trips `set -e` and fails the whole install (Code 112). So boot it out,
  # WAIT for it to actually leave the domain, then bootstrap with a few retries to absorb
  # the residual race. A bare bootout+bootstrap works on a fresh install but flakes on reinstall.
  uctl bootout "gui/$CUID/$label" 2>/dev/null || true
  while uctl print "gui/$CUID/$label" >/dev/null 2>&1; do
    i=$((i + 1)); [ "$i" -ge 40 ] && break; sleep 0.25   # ≤10s for the old label to clear
  done
  i=0
  until uctl bootstrap "gui/$CUID" "$out" 2>/dev/null; do
    i=$((i + 1))
    [ "$i" -ge 6 ] && { echo "failed to bootstrap $label after retries (launchctl EIO)" >&2; return 1; }
    sleep 0.5
  done
}

if [ "$ROLE" = "hub" ]; then
  render_load com.outerloop.hub.plist    com.outerloop.hub.plist
  # Tunnel always loads on the hub; its wrapper self-idles until relay config exists
  # (baked --vps/--ssh-key or set later in menu-bar Settings), so remote access can be
  # turned on at runtime with no rebuild. Idle = no connection, hub stays on loopback.
  render_load com.outerloop.tunnel.plist com.outerloop.tunnel.plist
  [ -n "${VPS_HOST:-}" ] || echo "no VPS_HOST baked: tunnel idle until set in menu-bar Settings (hub on 127.0.0.1:8765)"
  # the mini runs its own worker too, reaching the hub on loopback
  HUB_URL="http://127.0.0.1:8765" render_load com.outerloop.worker.plist com.outerloop.worker.plist
else
  render_load com.outerloop.worker.plist com.outerloop.worker.plist
fi

# menu-bar indicator (both roles)
render_load com.outerloop.menubar.plist com.outerloop.menubar.plist

echo "outerloop ($ROLE) installed and loaded for $CUSER"
exit 0
